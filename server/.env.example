PORT=3000

# مفضّل: Connection pooling (Transaction) من Supabase
# Settings → Database → Connect → Connection string → Transaction pooler
# DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# بديل بدون DATABASE_URL الكامل:
# SUPABASE_DB_PASSWORD=
# SUPABASE_PROJECT_REF=qlqzdtphwmoohqgqftuv
# SUPABASE_REGION=ap-southeast-2

# كلمة مرور صفحة إدارة المنصة /platform
PLATFORM_ADMIN_PASSWORD=change-me-strong-password

